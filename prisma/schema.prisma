// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String    // bcrypt hashed
  name          String?
  image         String?
  role          UserRole  @default(TENANT)

  // Account Status
  isActive      Boolean   @default(true)
  isSuspended   Boolean   @default(false)
  suspendedAt   DateTime?
  suspendedReason String?
  lastLoginAt   DateTime?
  lastActiveAt  DateTime?
  loginCount    Int       @default(0)

  // MFA (Multi-Factor Authentication)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?   // TOTP secret (encrypted)
  mfaBackupCodes String[] // Hashed backup codes
  mfaVerifiedAt DateTime?

  // Subscription
  subscriptionTier   SubscriptionTier @default(FREE)
  stripeCustomerId   String?          @unique
  stripeSubscriptionId String?        @unique
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionEndsAt DateTime?
  
  // Billing
  billingEmail       String?
  lastPaymentAt      DateTime?
  lastPaymentAmount  Decimal?
  failedPaymentCount Int       @default(0)
  nextBillingDate    DateTime?

  // Relations
  accounts      Account[]
  sessions      Session[]
  landlordProfile LandlordProfile?
  tenantProfile   TenantProfile?
  proProfile      ProProfile?
  tenantApplications TenantApplication[]
  featureOverrides UserFeatureOverride[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([subscriptionStatus])
  @@index([isActive])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Magic Link for passwordless authentication
model MagicLink {
  id          String   @id @default(cuid())
  email       String
  token       String   @unique
  expires     DateTime
  used        Boolean  @default(false)
  usedAt      DateTime?
  
  // For MFA flow - if user has MFA enabled, store pending session
  mfaPending  Boolean  @default(false)
  
  // Security tracking
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  @@index([email])
  @@index([token])
  @@index([expires])
}

// ============================================================================
// LANDLORD & TENANT PROFILES
// ============================================================================

model LandlordProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business Info
  phone           String?
  company         String?
  businessAddress String?

  // QuickBooks Integration
  quickbooksEnabled    Boolean @default(false)
  quickbooksCompanyId  String?
  quickbooksRealmId    String?
  quickbooksAccessToken String?
  quickbooksRefreshToken String?
  quickbooksTokenExpiry DateTime?

  // Relations
  properties      Property[]
  tenants         Tenant[]
  preferredPros   LandlordPro[]
  serviceRequests ServiceRequest[]
  documents       LandlordDocument[]
  lenders         Lender[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TenantProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Contact Info
  phone           String?
  emergencyContact String?
  emergencyPhone   String?

  // Current Rental
  currentTenancy  Tenant?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================================
// SERVICE PROFESSIONALS (PRO)
// ============================================================================

model ProProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Business Info
  businessName    String
  phone           String
  businessAddress String?
  city            String?
  state           String?
  zipCode         String?
  serviceRadius   Int      @default(25) // Miles willing to travel

  // Verification
  isVerified      Boolean  @default(false)
  licenseNumber   String?
  insuranceProvider String?
  insurancePolicyNumber String?
  insuranceExpiry DateTime?

  // Services Offered (e.g., PLUMBING, ELECTRICAL, HVAC, GENERAL)
  serviceCategories String[] // Array of service types
  specialties       String?  // Free text for specific skills

  // Rates
  hourlyRate      Decimal?
  callOutFee      Decimal?  // Minimum charge for showing up
  emergencyRate   Decimal?  // Rate for emergency calls

  // Availability
  availability    Json?     // Weekly schedule: {"monday": {"start": "08:00", "end": "17:00"}, ...}
  acceptsEmergency Boolean @default(false)

  // Stripe Connect for payments
  stripeConnectId      String?  @unique
  stripeConnectOnboarded Boolean @default(false)

  // Ratings
  averageRating   Float    @default(0)
  totalReviews    Int      @default(0)
  totalJobsCompleted Int   @default(0)

  // Profile
  bio             String?
  profilePhotoUrl String?
  portfolioPhotos String[] // Array of work sample URLs

  // Relations
  landlordConnections LandlordPro[]
  serviceRequests     ServiceRequest[]
  appointments        Appointment[]
  reviews             ProReview[]
  messages            ServiceMessage[]
  documents           ProDocument[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([zipCode])
  @@index([serviceCategories])
}

// Landlord <-> Pro relationship (preferred pros)
model LandlordPro {
  id              String   @id @default(cuid())
  landlordId      String
  landlord        LandlordProfile @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  proId           String
  pro             ProProfile @relation(fields: [proId], references: [id], onDelete: Cascade)

  // Relationship Status
  status          ProConnectionStatus @default(PENDING)
  invitedAt       DateTime @default(now())
  acceptedAt      DateTime?

  // How they connected
  invitedBy       InvitedBy @default(LANDLORD) // LANDLORD invited PRO, or PRO requested
  inviteEmail     String?   // Email used for invitation
  invitePhone     String?   // Phone used for SMS invitation

  // Preference
  isPrimary       Boolean  @default(false) // Primary pro for specific category
  primaryForCategory String? // e.g., "PLUMBING" - this pro is primary for plumbing

  // Notes
  landlordNotes   String?  // Private notes from landlord about this pro

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([landlordId, proId])
  @@index([landlordId])
  @@index([proId])
}

// Service Request (enhanced maintenance request)
model ServiceRequest {
  id              String   @id @default(cuid())
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  landlordId      String
  landlord        LandlordProfile @relation(fields: [landlordId], references: [id])

  // Optional: linked to tenant who reported
  tenantId        String?
  reportedByTenantName String?
  reportedByTenantPhone String?
  reportedByTenantEmail String?

  // Assigned Pro
  proId           String?
  pro             ProProfile? @relation(fields: [proId], references: [id])
  assignedAt      DateTime?

  // Request Details
  title           String
  description     String
  category        ServiceCategory
  priority        Priority @default(MEDIUM)
  status          ServiceRequestStatus @default(SUBMITTED)

  // Photos from tenant/landlord
  photos          String[]  // Array of URLs

  // AI-Generated Scope of Work
  scopeOfWork     ScopeOfWork?

  // Scheduling
  preferredDate   DateTime?
  preferredTimeSlot String?  // e.g., "morning", "afternoon", "evening"
  scheduledDate   DateTime?
  scheduledTime   String?

  // Completion
  completedAt     DateTime?
  completionNotes String?
  completionPhotos String[]  // Before/after photos from Pro

  // Payment
  estimatedCost   Decimal?
  finalCost       Decimal?
  paymentStatus   ServicePaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  paidAt          DateTime?

  // Relations
  changeOrders    ChangeOrder[]
  messages        ServiceMessage[]
  appointments    Appointment[]
  review          ProReview?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([propertyId])
  @@index([landlordId])
  @@index([proId])
  @@index([status])
}

// AI-generated Scope of Work
model ScopeOfWork {
  id              String   @id @default(cuid())
  serviceRequestId String  @unique
  serviceRequest  ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  // AI Analysis
  problemSummary  String   // AI summary of the problem
  workDescription String   // Detailed description of work needed
  materialsNeeded Json?    // [{"item": "...", "quantity": 1, "estimatedCost": 50}]
  laborEstimate   String?  // e.g., "2-3 hours"

  // Cost Estimates
  estimatedLaborCost   Decimal?
  estimatedMaterialCost Decimal?
  estimatedTotalCost   Decimal?
  costRange            String?  // e.g., "$150 - $250"

  // Complexity
  complexity      JobComplexity @default(MODERATE)
  urgencyReason   String?       // Why AI thinks it's urgent (if applicable)

  // Recommendations
  suggestedCategory ServiceCategory?
  diyPossible       Boolean @default(false)
  diyInstructions   String?
  requiresPermit    Boolean @default(false)
  permitNotes       String?

  // Approval
  approvedByLandlord Boolean @default(false)
  approvedAt         DateTime?
  landlordNotes      String?

  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Change Order (additional work during service)
model ChangeOrder {
  id              String   @id @default(cuid())
  serviceRequestId String
  serviceRequest  ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  // Change Details
  title           String
  description     String
  reason          String   // Why additional work is needed
  photos          String[] // Photos showing why change is needed

  // Cost
  additionalCost  Decimal
  laborCost       Decimal?
  materialCost    Decimal?

  // Approval
  status          ChangeOrderStatus @default(PENDING)
  submittedAt     DateTime @default(now())
  landlordResponse String?
  respondedAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([serviceRequestId])
}

// Messages between Pro and Tenant (after dispatch)
model ServiceMessage {
  id              String   @id @default(cuid())
  serviceRequestId String
  serviceRequest  ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  // Sender
  senderType      MessageSenderType
  senderId        String   // Could be Pro, Tenant, or Landlord userId/profileId
  senderName      String

  // Optional: Pro reference
  proId           String?
  pro             ProProfile? @relation(fields: [proId], references: [id])

  // Message Content
  message         String
  attachments     String[] // Photo/file URLs

  // Read Status
  readAt          DateTime?

  createdAt       DateTime @default(now())

  @@index([serviceRequestId])
  @@index([senderId])
}

// Appointment/Scheduling
model Appointment {
  id              String   @id @default(cuid())
  proId           String
  pro             ProProfile @relation(fields: [proId], references: [id], onDelete: Cascade)

  // Optional: linked to service request
  serviceRequestId String?
  serviceRequest  ServiceRequest? @relation(fields: [serviceRequestId], references: [id])

  // Appointment Details
  title           String
  description     String?
  propertyAddress String

  // Scheduling
  scheduledDate   DateTime
  startTime       String   // e.g., "09:00"
  endTime         String?  // e.g., "11:00"
  duration        Int?     // Minutes

  // Status
  status          AppointmentStatus @default(SCHEDULED)
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?

  // Reminders
  reminderSent    Boolean @default(false)
  reminderSentAt  DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([proId, scheduledDate])
  @@index([serviceRequestId])
}

// Pro Reviews from Landlords/Tenants
model ProReview {
  id              String   @id @default(cuid())
  proId           String
  pro             ProProfile @relation(fields: [proId], references: [id], onDelete: Cascade)

  // Linked to specific service request
  serviceRequestId String  @unique
  serviceRequest  ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  // Reviewer
  reviewerType    ReviewerType
  reviewerId      String
  reviewerName    String

  // Rating
  overallRating   Int      // 1-5 stars
  qualityRating   Int?     // 1-5
  timelinessRating Int?    // 1-5
  communicationRating Int? // 1-5
  valueRating     Int?     // 1-5

  // Review Content
  title           String?
  comment         String?
  photos          String[] // Work result photos

  // Visibility
  isPublic        Boolean @default(true)

  // Pro Response
  proResponse     String?
  proRespondedAt  DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([proId])
}

// ============================================================================
// PRO-RELATED ENUMS
// ============================================================================

enum ServiceCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  APPLIANCE_REPAIR
  ROOFING
  PAINTING
  FLOORING
  CARPENTRY
  LANDSCAPING
  PEST_CONTROL
  CLEANING
  LOCKSMITH
  GENERAL_HANDYMAN
  OTHER
}

enum ProConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum InvitedBy {
  LANDLORD
  PRO
}

enum ServiceRequestStatus {
  SUBMITTED       // Tenant/landlord submitted
  REVIEWING       // Landlord reviewing SOW
  PENDING_DISPATCH // Approved, waiting for pro assignment
  DISPATCHED      // Assigned to pro
  SCHEDULED       // Pro has scheduled appointment
  IN_PROGRESS     // Pro is working on it
  PENDING_APPROVAL // Pro completed, waiting for landlord approval
  COMPLETED       // All done
  CANCELLED
}

enum ServicePaymentStatus {
  PENDING
  INVOICED
  PAID
  REFUNDED
  DISPUTED
}

enum JobComplexity {
  SIMPLE
  MODERATE
  COMPLEX
  REQUIRES_SPECIALIST
}

enum ChangeOrderStatus {
  PENDING
  APPROVED
  DENIED
}

enum MessageSenderType {
  TENANT
  LANDLORD
  PRO
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReviewerType {
  LANDLORD
  TENANT
}

// ============================================================================
// PROPERTIES
// ============================================================================

model Property {
  id              String   @id @default(cuid())
  landlordId      String
  landlord        LandlordProfile @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  // Property Details (auto-fetched from Zillow)
  address         String
  city            String
  state           String
  zipCode         String
  latitude        Float?
  longitude       Float?

  bedrooms        Int
  bathrooms       Float
  squareFeet      Int?
  yearBuilt       Int?
  propertyType    String
  estimatedValue  Decimal?

  // Landlord Purchase Info
  purchasePrice   Decimal?
  purchaseDate    DateTime?

  // Mortgage Details
  monthlyMortgage Decimal?
  mortgageBalance Decimal?      // Current amount owed
  mortgageRate    Float?         // Interest rate
  mortgageTerm    Int?           // Term in months (e.g., 360 for 30 years)
  mortgageStartDate DateTime?
  lenderName      String?
  loanNumber      String?

  // Equity Tracking
  currentValue    Decimal?       // Auto-updated from Zillow API
  availableEquity Decimal?       // Calculated: currentValue - mortgageBalance
  lastValueUpdate DateTime?

  // Bank Integration (Plaid)
  plaidAccessToken String?
  plaidItemId      String?
  plaidAccountId   String?
  plaidLinked      Boolean @default(false)
  plaidLastSync    DateTime?

  // Payment Status
  mortgagePaymentStatus String? // CURRENT, LATE, BEHIND
  lastPaymentDate       DateTime?
  nextPaymentDue        DateTime?
  missedPayments        Int @default(0)

  // Refinance Tracking
  shouldConsiderRefi  Boolean @default(false)
  refiRecommendation  String?  // System-generated recommendation

  // Rental Info
  monthlyRent     Decimal?
  marketRent      Decimal?       // Market rate rent from AI analysis
  securityDeposit Decimal?

  // Section 8 Housing Info
  section8FMR     Decimal?       // HUD Fair Market Rent for this property
  section8ContactName    String?  // Local housing authority name
  section8ContactPhone   String?  // Housing authority phone
  section8ContactWebsite String?  // Housing authority website

  // Status
  status          PropertyStatus @default(VACANT)

  // Relations
  currentTenancy  Tenant?
  photos          PropertyPhoto[]
  maintenanceRequests MaintenanceRequest[]
  serviceRequests ServiceRequest[]
  rentPayments    RentPayment[]
  tenantApplications TenantApplication[]
  weatherData     WeatherData[]
  landlordDocuments LandlordDocument[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([landlordId])
  @@index([zipCode])
}

model PropertyPhoto {
  id              String   @id @default(cuid())
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Storage (cloud-agnostic)
  storageProvider StorageProvider
  s3Bucket        String?
  s3Key           String?
  gcsBucket       String?
  gcsPath         String?
  azureContainer  String?
  azurePath       String?

  imageUrl        String   // CDN URL
  thumbnailUrl    String?

  photoType       PhotoType
  uploadedBy      String   // userId
  uploadedAt      DateTime @default(now())

  // AI Analysis
  aiAnalyzed      Boolean @default(false)
  aiDamageDetected Boolean @default(false)
  damageDescription String?
  estimatedRepairCost Decimal?
  damageCategory  String?
  aiConfidence    Float?   // 0-1 confidence score

  // Auto-deletion for tenant photos
  deleteAt        DateTime? // Set when tenant moves out

  @@index([propertyId, photoType])
}

// ============================================================================
// TENANTS & LEASES
// ============================================================================

model Tenant {
  id              String   @id @default(cuid())

  // User Account
  tenantProfileId String   @unique
  tenantProfile   TenantProfile @relation(fields: [tenantProfileId], references: [id], onDelete: Cascade)

  // Landlord Relationship
  landlordId      String
  landlord        LandlordProfile @relation(fields: [landlordId], references: [id])

  // Property Assignment
  propertyId      String   @unique
  property        Property @relation(fields: [propertyId], references: [id])

  // Lease Terms
  leaseStartDate  DateTime
  leaseEndDate    DateTime
  monthlyRent     Decimal
  securityDeposit Decimal
  leaseSigned     Boolean @default(false)
  leaseSignedDate DateTime?

  // Auto-Pay
  autoPayEnabled  Boolean @default(false)
  autoPayMethod   String? // STRIPE, ACH

  // Relations
  rentPayments    RentPayment[]
  maintenanceRequests MaintenanceRequest[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([landlordId])
  @@index([propertyId])
}

// ============================================================================
// RENT PAYMENTS
// ============================================================================

model RentPayment {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id])

  // Payment Details
  amount          Decimal
  dueDate         DateTime
  paidDate        DateTime?
  status          PaymentStatus @default(PENDING)

  // Payment Method
  paymentMethod   PaymentMethod?

  // Stripe
  stripePaymentIntentId String?
  stripeChargeId        String?

  // ACH
  plaidAccountId        String?

  // Venmo/Zelle
  externalTransactionId String?

  // Late Fees
  lateFee         Decimal?
  lateFeeApplied  DateTime?

  // QuickBooks Sync
  quickbooksSynced Boolean @default(false)
  quickbooksInvoiceId String?
  quickbooksPaymentId String?
  quickbooksSyncedAt  DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, dueDate])
  @@index([status])
}

// ============================================================================
// MAINTENANCE REQUESTS
// ============================================================================

model MaintenanceRequest {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id])

  title           String
  description     String
  priority        Priority @default(MEDIUM)
  status          RequestStatus @default(OPEN)
  category        String?  // PLUMBING, ELECTRICAL, HVAC, etc.

  // Photos
  photos          MaintenancePhoto[]

  // AI Analysis
  aiAnalyzed      Boolean @default(false)
  aiEstimatedCost Decimal?
  aiDescription   String?
  aiUrgency       Priority?
  aiContractorSuggestion String?

  // Contractor Assignment
  assignedTo      String?
  scheduledDate   DateTime?

  createdAt       DateTime @default(now())
  resolvedAt      DateTime?
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([propertyId, status])
}

model MaintenancePhoto {
  id              String   @id @default(cuid())
  requestId       String
  request         MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  // Storage (cloud-agnostic)
  storageProvider StorageProvider
  s3Key           String?
  gcsPath         String?
  azurePath       String?

  imageUrl        String
  thumbnailUrl    String?

  uploadedAt      DateTime @default(now())

  // Auto-deletion when request resolved + 90 days
  deleteAt        DateTime?

  @@index([requestId])
}

// ============================================================================
// WEATHER DATA (Cached)
// ============================================================================

model WeatherData {
  id              String   @id @default(cuid())
  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Location
  zipCode         String
  city            String
  state           String

  // Current Weather
  temperature     Float
  feelsLike       Float
  humidity        Int
  condition       String   // SUNNY, CLOUDY, RAINY, etc.
  windSpeed       Float

  // Forecast
  forecastData    Json?    // 7-day forecast

  // Cache
  fetchedAt       DateTime @default(now())
  expiresAt       DateTime // Refresh every 30 minutes

  @@index([propertyId])
  @@index([expiresAt])
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  SUPER_ADMIN  // Full platform control
  ADMIN        // Company admin (future multi-company support)
  LANDLORD
  TENANT
  PRO
}

// ============================================================================
// FEATURE FLAGS & SYSTEM SETTINGS
// ============================================================================

model FeatureFlag {
  id              String   @id @default(cuid())
  
  // Feature identification
  key             String   @unique  // e.g., "lenders", "documents", "pro_marketplace"
  name            String            // Human readable name
  description     String?
  
  // Global toggle
  isEnabled       Boolean  @default(true)
  
  // Per-tier settings (which tiers have access)
  enabledForFree       Boolean @default(false)
  enabledForPro        Boolean @default(true)
  enabledForEnterprise Boolean @default(true)
  
  // Per-role settings
  enabledForLandlords  Boolean @default(true)
  enabledForTenants    Boolean @default(false)
  enabledForPros       Boolean @default(false)
  
  // Optional limits per tier
  freeTierLimit        Int?    // e.g., 2 properties for free tier
  proTierLimit         Int?    // e.g., 25 properties for pro
  enterpriseTierLimit  Int?    // null = unlimited
  
  // Metadata
  category        String?  // CORE, PREMIUM, BETA, etc.
  sortOrder       Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([key])
  @@index([category])
}

model SystemSetting {
  id              String   @id @default(cuid())
  
  key             String   @unique
  value           String
  type            SettingType @default(STRING)
  description     String?
  
  // Grouping
  category        String   @default("general")
  
  // Security
  isPublic        Boolean  @default(false)  // Can non-admins see this?
  isEditable      Boolean  @default(true)   // Can it be changed via UI?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([category])
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

// Audit log for admin actions
model AdminAuditLog {
  id              String   @id @default(cuid())
  
  adminId         String   // AdminUser ID who performed action
  adminEmail      String
  
  action          String   // e.g., "USER_SUSPENDED", "FEATURE_TOGGLED"
  targetType      String?  // e.g., "User", "FeatureFlag"
  targetId        String?  // ID of affected record
  
  details         Json?    // Additional context
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime @default(now())
  
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================================
// ADMIN USERS (Separate from regular users)
// ============================================================================

model AdminUser {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String   // bcrypt hashed
  name            String
  role            AdminRole @default(SUPPORT)
  
  // Status
  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?
  loginCount      Int      @default(0)
  
  // MFA
  mfaEnabled      Boolean  @default(false)
  mfaSecret       String?
  mfaBackupCodes  String[]
  
  // Password reset
  resetToken      String?
  resetTokenExpiry DateTime?
  
  // Sessions
  sessions        AdminSession[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?  // AdminUser ID who created this admin
  
  @@index([email])
}

model AdminSession {
  id              String   @id @default(cuid())
  adminId         String
  admin           AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  
  token           String   @unique
  expiresAt       DateTime
  
  // Session metadata
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime @default(now())
  
  @@index([adminId])
  @@index([token])
  @@index([expiresAt])
}

enum AdminRole {
  SUPER_ADMIN  // Full access - can create other admins
  ADMIN        // Full access to user/feature management
  SUPPORT      // View-only access, can suspend users
  BILLING      // Access to billing/subscription management only
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum PropertyStatus {
  VACANT
  RENTED
  MAINTENANCE
  PENDING_LEASE
}

enum PhotoType {
  MOVE_IN
  MOVE_OUT
  MAINTENANCE
  GENERAL
}

enum StorageProvider {
  AWS_S3
  GCP_STORAGE
  AZURE_BLOB
}

enum PaymentMethod {
  STRIPE_CARD
  STRIPE_ACH
  PLAID_ACH
  VENMO
  ZELLE
  CASH
  CHECK
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  LATE
  FAILED
  REFUNDED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum RequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================================================
// TENANT APPLICATIONS
// ============================================================================

enum ApplicationStatus {
  PENDING
  SUBMITTED
  REVIEWING
  APPROVED
  DENIED
}

model TenantApplication {
  id                  String            @id @default(cuid())
  propertyId          String
  landlordId          String
  applicationLink     String            @unique
  status              ApplicationStatus @default(PENDING)

  // Primary Applicant Info
  fullName            String?
  email               String?
  phone               String?
  dateOfBirth         DateTime?
  ssn                 String?

  // Current Employment
  employerName        String?
  employerPhone       String?
  jobTitle            String?
  monthlyIncome       Float?
  employmentStartDate DateTime?

  // Previous Employment (if less than 2 years)
  previousEmployerName        String?
  previousEmployerPhone       String?
  previousJobTitle            String?
  previousEmploymentStartDate DateTime?
  previousEmploymentEndDate   DateTime?

  // References
  reference1Name         String?
  reference1Phone        String?
  reference1Relationship String?
  reference2Name         String?
  reference2Phone        String?
  reference2Relationship String?

  // Current Address
  currentAddress       String?
  currentCity          String?
  currentState         String?
  currentZip           String?
  currentLandlord      String?
  currentLandlordPhone String?
  currentMonthlyRent   Float?
  currentMoveInDate    DateTime?

  // Previous Address (if less than 2 years at current)
  previousAddress       String?
  previousCity          String?
  previousState         String?
  previousZip           String?
  previousLandlord      String?
  previousLandlordPhone String?

  // Pets
  hasPets    Boolean @default(false)
  petDetails Json?

  // Additional Occupants
  additionalOccupants Json?

  // Second Applicant
  hasSecondApplicant Boolean @default(false)
  secondApplicantInfo Json?

  // Documents
  payStubsUrls  String[]
  idDocumentUrl String?

  // Screening Results
  creditCheckId            String?
  creditScore              Int?
  creditReportUrl          String?
  backgroundCheckId        String?
  backgroundCheckStatus    String?
  backgroundCheckReportUrl String?

  // Payment
  applicationFee         Float   @default(50.00)
  applicationFeePaid     Boolean @default(false)
  stripePaymentIntentId  String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  submittedAt DateTime?

  // Relations
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  landlord User     @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([landlordId])
  @@index([applicationLink])
}

// ============================================================================
// DOCUMENTS
// ============================================================================

// Pro Documents (licenses, insurance, certifications)
model ProDocument {
  id              String   @id @default(cuid())
  proId           String
  pro             ProProfile @relation(fields: [proId], references: [id], onDelete: Cascade)

  // Document Info
  name            String
  type            ProDocumentType
  description     String?

  // File Storage
  fileUrl         String
  fileName        String
  fileSize        Int?     // bytes
  mimeType        String?

  // Expiration Tracking
  issueDate       DateTime?
  expirationDate  DateTime?
  isExpired       Boolean  @default(false)

  // Verification
  isVerified      Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?  // Admin userId who verified

  uploadedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([proId])
  @@index([type])
  @@index([expirationDate])
}

enum ProDocumentType {
  LICENSE
  INSURANCE_CERTIFICATE
  BOND
  CERTIFICATION
  W9
  BUSINESS_LICENSE
  OTHER
}

// Landlord Documents (tax statements, insurance, general docs)
model LandlordDocument {
  id              String   @id @default(cuid())
  landlordId      String
  landlord        LandlordProfile @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  // Optional: link to specific property
  propertyId      String?
  property        Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // Document Info
  name            String
  type            LandlordDocumentType
  description     String?
  year            Int?     // For tax documents

  // File Storage
  fileUrl         String
  fileName        String
  fileSize        Int?
  mimeType        String?

  // Expiration Tracking
  expirationDate  DateTime?
  isExpired       Boolean  @default(false)

  uploadedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([landlordId])
  @@index([propertyId])
  @@index([type])
}

enum LandlordDocumentType {
  TAX_RETURN
  TAX_STATEMENT
  PROPERTY_TAX
  INSURANCE_POLICY
  INSURANCE_CERTIFICATE
  LEASE_AGREEMENT
  LEASE_ADDENDUM
  PROPERTY_DEED
  TITLE_INSURANCE
  MORTGAGE_STATEMENT
  BANK_STATEMENT
  INSPECTION_REPORT
  APPRAISAL
  HOA_DOCUMENTS
  UTILITY_BILLS
  CONTRACTOR_AGREEMENT
  OTHER
}

// ============================================================================
// LENDERS
// ============================================================================

model Lender {
  id              String   @id @default(cuid())
  landlordId      String
  landlord        LandlordProfile @relation(fields: [landlordId], references: [id], onDelete: Cascade)

  // Lender Info
  name            String
  type            LenderType
  contactName     String?
  email           String?
  phone           String?
  website         String?
  address         String?
  city            String?
  state           String?
  zipCode         String?

  // Loan Terms (typical)
  minLoanAmount   Decimal?
  maxLoanAmount   Decimal?
  interestRateMin Float?   // e.g., 6.5
  interestRateMax Float?   // e.g., 12.0
  ltvMax          Float?   // Max Loan-to-Value percentage
  termMonthsMin   Int?     // e.g., 12
  termMonthsMax   Int?     // e.g., 360
  pointsMin       Float?   // Origination points
  pointsMax       Float?

  // For Hard Money / Private
  minCreditScore  Int?
  requiresAppraisal Boolean @default(true)
  requiresIncome  Boolean @default(true)
  timeToClose     String?  // e.g., "7-14 days"

  // Specialties
  loanTypes       String[] // PURCHASE, REFINANCE, CASH_OUT, CONSTRUCTION, BRIDGE
  propertyTypes   String[] // SFR, MULTI_FAMILY, COMMERCIAL, LAND

  // Notes
  notes           String?
  rating          Int?     // 1-5 star rating
  lastContactDate DateTime?

  // Status
  isActive        Boolean  @default(true)
  isFavorite      Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([landlordId])
  @@index([type])
}

enum LenderType {
  BANK
  CREDIT_UNION
  MORTGAGE_COMPANY
  HARD_MONEY
  PRIVATE_INVESTOR
  CROWDFUNDING
  OTHER
}

// ============================================================================
// USER FEATURE OVERRIDES (Per-user feature control)
// ============================================================================

model UserFeatureOverride {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  featureKey      String   // e.g., "lenders", "pro_marketplace", "quickbooks_sync"
  enabled         Boolean  // true = force enabled, false = force disabled
  
  // Audit
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?  // Admin who set the override
  
  @@unique([userId, featureKey])
  @@index([userId])
  @@index([featureKey])
}
