# Database
DATABASE_URL="postgresql://user:password@localhost:5432/realestate_investor"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# OpenAI for AI Analysis (Required for CMA and lease generation)
OPENAI_API_KEY="sk-..."

# Property Data APIs

# Option 1: FREE Sources (No API keys needed!)
# ✅ County Records - Scrapes public county assessor data (built-in)
# ✅ Craigslist - Finds owner-finance and FSBO properties (built-in)

# Option 2: Bright Data (RECOMMENDED - Best value!)
# $250 for 100K records (one-time) OR $0.75/1K requests
# Sign up: https://brightdata.com/products/datasets/real-estate
BRIGHT_DATA_API_TOKEN=""  # Get from Bright Data dashboard
BRIGHT_DATA_DATASET_ID="gd_lwh4f6i08oqu8aw1q5"  # Zillow dataset ID

# Option 3: RapidAPI (Alternative - More expensive)
# ~$10-20/month, Sign up: https://rapidapi.com/
ZILLOW_API_KEY=""  # Optional: Zillow via RapidAPI ~$0.002/request
REALTOR_API_KEY=""  # Optional: Realtor.com via RapidAPI ~$0.005/request

# Crime Data APIs
# SpotCrime - FREE (no key needed for basic scraping)
# FBI Crime Data - FREE but limited
SPOTCRIME_API_KEY=""  # Optional: For higher rate limits
FBI_CRIME_DATA_API_KEY=""  # Optional: May not be needed

# File Upload (Optional - for tenant portal)
CLOUDINARY_URL=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ========================================
# SMS Notifications (Choose ONE option)
# ========================================

# Option 1: Twilio (RECOMMENDED - Easier to set up)
# Sign up: https://www.twilio.com/ (free trial includes $15 credit)
# Cost: ~$0.0075/SMS for US numbers
TWILIO_ACCOUNT_SID=""       # From Twilio Console dashboard
TWILIO_AUTH_TOKEN=""        # From Twilio Console dashboard
TWILIO_PHONE_NUMBER=""      # Your Twilio phone number (+1XXXXXXXXXX)

# Option 2: AWS SNS (Alternative - More complex setup)
# Requires AWS account with SMS sandbox approval for production
SNS_ACCESS_KEY_ID=""
SNS_SECRET_ACCESS_KEY=""
SNS_REGION="us-east-1"

# ========================================
# Email Notifications
# ========================================

# Option 1: AWS SES (Default - uses same credentials as SNS)
# Make sure to verify email addresses in AWS SES console
EMAIL_FROM="noreply@yourdomain.com"

# Option 2: SMTP (Alternative)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# ========================================
# Cost Breakdown
# ========================================
# - FREE: County records, Craigslist, SpotCrime ($0/month)
# - Bright Data: $250 for 100K records (one-time) + $10/month for updates
# - AI Analysis: OpenAI (~$0.01-0.05 per analysis)
# - SMS: Twilio ~$0.0075/SMS or AWS SNS ~$0.00645/SMS
# - Email: AWS SES ~$0.10/1000 emails
#
# Recommended Setup:
# Year 1: $250 (Bright Data) + $120 (updates) + $50 (OpenAI) + $20 (SMS) = $440
# Year 2+: $120/year (just updates) + ~$50 ongoing
